#!/usr/bin/env bash
set -euo pipefail

# Start tmux session if not already inside one
if [ -z "${TMUX:-}" ]; then
  exec tmux new-session "$0" "$@"
fi

# Get current branch or worktree name
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")

# Sanitize: replace non-alphanumeric chars with hyphens, collapse multiple hyphens
sanitized=$(echo "$branch" | sed 's/[^a-zA-Z0-9]/-/g; s/-\{2,\}/-/g; s/^-//; s/-$//')

export CLAUDE_CODE_TASK_LIST_ID="$sanitized"

exec claude "$@"
